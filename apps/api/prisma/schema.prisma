// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  passwordHash       String
  nativeLanguage     String         @default("en")
  refreshTokenHash   String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  settings           UserSettings?
  progress           UserProgress[]
  points             PointsLedger[]

  @@map("users")
}

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  learningMode  String   @default("BOTH") // "KR" | "JP" | "BOTH"
  notifications Boolean  @default(true)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ──────────────────────────────────────────────
// Curriculum / Lesson / Card
// ──────────────────────────────────────────────

model Curriculum {
  id          String   @id @default(cuid())
  title       String
  description String?
  language    String   // "KR" | "JP" | "BOTH"
  level       String   // "beginner" | "intermediate" | "advanced"
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  lessons     Lesson[]

  @@map("curriculums")
}

model Lesson {
  id           String       @id @default(cuid())
  curriculumId String
  title        String
  description  String?
  order        Int          @default(0)
  createdAt    DateTime     @default(now())
  curriculum   Curriculum   @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  cards        Card[]
  progress     UserProgress[]

  @@map("lessons")
}

model Card {
  id          String         @id @default(cuid())
  lessonId    String
  type        String         @default("WORD") // "WORD" | "SENTENCE" | "GRAMMAR"
  en          String
  ko          String
  ja          String
  koReading   String?
  jaReading   String?
  order       Int            @default(0)
  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress    UserProgress[]

  @@map("cards")
}

// ──────────────────────────────────────────────
// Learning Progress
// ──────────────────────────────────────────────

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  cardId      String?
  correct     Boolean  @default(false)
  latencyMs   Int?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  card        Card?    @relation(fields: [cardId], references: [id])

  @@map("user_progress")
}

// ──────────────────────────────────────────────
// Points Ledger
// ──────────────────────────────────────────────

model PointsLedger {
  id        String   @id @default(cuid())
  userId    String
  delta     Int      // positive = earn, negative = spend
  reason    String   // "LESSON_COMPLETE" | "CARD_CORRECT" | etc.
  refId     String?  // lessonId or cardId for traceability
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("points_ledger")
}

// ──────────────────────────────────────────────
// Dictionary
// ──────────────────────────────────────────────

model DictionaryEntry {
  id         String   @id @default(cuid())
  en         String
  ko         String
  ja         String
  koReading  String?
  jaReading  String?
  tags       String[] // e.g. ["food", "travel"]
  examples   Json?    // [{ en, ko, ja }]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([en])
  @@map("dictionary_entries")
}
